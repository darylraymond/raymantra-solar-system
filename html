function SolarSystem() {
  const mountRef = useRef(null);
  const sceneRef = useRef(null);
  const cameraRef = useRef(null);
  const rendererRef = useRef(null);
  const planetMeshesRef = useRef([]);
  const moonMeshesRef = useRef([]);
  const sunMeshRef = useRef(null);
  const frameRef = useRef(null);
  const timeRef = useRef(0);
  const mouseRef = useRef({ isDown: false, lastX: 0, lastY: 0 });
  const cameraAngleRef = useRef({ theta: 0.4, phi: 1.0, radius: 80 });
  const raycasterRef = useRef(new THREE.Raycaster());
  const mouseVecRef = useRef(new THREE.Vector2());

  const [selected, setSelected] = useState(null);
  const [simSpeed, setSimSpeed] = useState(1);
  const [showOrbits, setShowOrbits] = useState(true);
  const [showLabels, setShowLabels] = useState(true);
  const [showConstellations, setShowConstellations] = useState(true);
  const [isPaused, setIsPaused] = useState(false);

  const initScene = useCallback(() => {
    const container = mountRef.current;
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0f171f);
    sceneRef.current = scene;

    const camera = new THREE.PerspectiveCamera(50, w / h, 0.1, 2000);
    cameraRef.current = camera;

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);
    rendererRef.current = renderer;

    // Stars
    const starGeo = new THREE.BufferGeometry();
    const starCount = 3000;
    const starPos = new Float32Array(starCount * 3);
    const starSizes = new Float32Array(starCount);
    for (let i = 0; i < starCount; i++) {
      const r = 500 + Math.random() * 500;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      starPos[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      starPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      starPos[i * 3 + 2] = r * Math.cos(phi);
      starSizes[i] = 0.5 + Math.random() * 1.5;
    }
    starGeo.setAttribute("position", new THREE.BufferAttribute(starPos, 3));
    starGeo.setAttribute("size", new THREE.BufferAttribute(starSizes, 1));
    const starMat = new THREE.PointsMaterial({ color: 0xffffff, size: 1, sizeAttenuation: true });
    scene.add(new THREE.Points(starGeo, starMat));

    // Constellations
    const constellationGroup = new THREE.Group();
    constellationGroup.name = "constellations";
    CONSTELLATIONS.forEach(c => {
      const lineMat = new THREE.LineBasicMaterial({ color: 0x334466, transparent: true, opacity: 0.4 });
      c.lines.forEach(([a, b]) => {
        const pts = [a, b].map(i => {
          const s = c.stars[i];
          const th = (s[0] / 100) * Math.PI;
          const ph = (s[1] / 100) * Math.PI + Math.PI / 2;
          const r = 480;
          return new THREE.Vector3(r * Math.sin(ph) * Math.cos(th), r * Math.cos(ph), r * Math.sin(ph) * Math.sin(th));
        });
        const geo = new THREE.BufferGeometry().setFromPoints(pts);
        constellationGroup.add(new THREE.Line(geo, lineMat));
      });
      c.stars.forEach(s => {
        const th = (s[0] / 100) * Math.PI;
        const ph = (s[1] / 100) * Math.PI + Math.PI / 2;
        const r = 480;
        const starMesh = new THREE.Mesh(
          new THREE.SphereGeometry(1.2, 6, 6),
          new THREE.MeshBasicMaterial({ color: 0x6688bb })
        );
        starMesh.position.set(r * Math.sin(ph) * Math.cos(th), r * Math.cos(ph), r * Math.sin(ph) * Math.sin(th));
        constellationGroup.add(starMesh);
      });
    });
    scene.add(constellationGroup);

    // Ambient light
    scene.add(new THREE.AmbientLight(0x333340, 0.6));
    const pointLight = new THREE.PointLight(0xffffff, 2, 300);
    pointLight.position.set(0, 0, 0);
    scene.add(pointLight);

    // Sun
    const sunGeo = new THREE.SphereGeometry(3, 32, 32);
    const sunMat = new THREE.MeshBasicMaterial({ color: 0xffcc33 });
    const sun = new THREE.Mesh(sunGeo, sunMat);
    sun.userData = { type: "sun" };
    scene.add(sun);
    sunMeshRef.current = sun;

    // Sun glow
    const glowGeo = new THREE.SphereGeometry(4, 32, 32);
    const glowMat = new THREE.MeshBasicMaterial({ color: 0xffaa00, transparent: true, opacity: 0.15 });
    scene.add(new THREE.Mesh(glowGeo, glowMat));

    const glowGeo2 = new THREE.SphereGeometry(5.5, 32, 32);
    const glowMat2 = new THREE.MeshBasicMaterial({ color: 0xff8800, transparent: true, opacity: 0.06 });
    scene.add(new THREE.Mesh(glowGeo2, glowMat2));

    // Planets
    planetMeshesRef.current = [];
    moonMeshesRef.current = [];

    PLANET_DATA.forEach((planet, pi) => {
      const group = new THREE.Group();
      group.userData = { type: "planet", index: pi, name: planet.name };

      const pGeo = new THREE.SphereGeometry(planet.radius, 24, 24);
      const pMat = new THREE.MeshStandardMaterial({ color: planet.color, roughness: 0.7, metalness: 0.1 });
      const pMesh = new THREE.Mesh(pGeo, pMat);
      pMesh.userData = { type: "planet", index: pi, name: planet.name };
      group.add(pMesh);

      // Rings
      if (planet.rings) {
        const ringGeo = new THREE.RingGeometry(planet.ringInner, planet.ringOuter, 64);
        const ringMat = new THREE.MeshBasicMaterial({
          color: planet.ringColor ? parseInt(planet.ringColor.slice(1, 7), 16) : 0xccccaa,
          side: THREE.DoubleSide,
          transparent: true,
          opacity: 0.5
        });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        ring.rotation.x = Math.PI / 2;
        group.add(ring);
      }

      // Moons
      planet.moons.forEach((moon, mi) => {
        const mGeo = new THREE.SphereGeometry(moon.radius, 12, 12);
        const mMat = new THREE.MeshStandardMaterial({ color: moon.color, roughness: 0.8 });
        const mMesh = new THREE.Mesh(mGeo, mMat);
        mMesh.userData = { type: "moon", planetIndex: pi, moonIndex: mi, name: moon.name };
        group.add(mMesh);
        moonMeshesRef.current.push({ mesh: mMesh, data: moon, planetIndex: pi });
      });

      scene.add(group);
      planetMeshesRef.current.push({ group, data: planet });

      // Orbit line
      if (showOrbits) {
        const orbitPts = [];
        for (let i = 0; i <= 128; i++) {
          const angle = (i / 128) * Math.PI * 2;
          orbitPts.push(new THREE.Vector3(Math.cos(angle) * planet.distance, 0, Math.sin(angle) * planet.distance));
        }
        const orbitGeo = new THREE.BufferGeometry().setFromPoints(orbitPts);
        const orbitLine = new THREE.Line(orbitGeo, new THREE.LineBasicMaterial({ color: 0x334455, transparent: true, opacity: 0.3 }));
        orbitLine.name = `orbit_${pi}`;
        scene.add(orbitLine);
      }
    });

    updateCamera();
  }, []);

  const updateCamera = useCallback(() => {
    if (!cameraRef.current) return;
    const { theta, phi, radius } = cameraAngleRef.current;
    cameraRef.current.position.set(
      radius * Math.sin(phi) * Math.cos(theta),
      radius * Math.cos(phi),
      radius * Math.sin(phi) * Math.sin(theta)
    );
    cameraRef.current.lookAt(0, 0, 0);
  }, []);

  const animate = useCallback(() => {
    frameRef.current = requestAnimationFrame(animate);
    if (!isPaused) {
      timeRef.current += 0.005 * simSpeed;
    }
    const t = timeRef.current;

    planetMeshesRef.current.forEach(({ group, data }, pi) => {
      const angle = t * data.speed;
      const x = Math.cos(angle) * data.distance;
      const z = Math.sin(angle) * data.distance;
      group.position.set(x, 0, z);
      group.rotation.y = t * 2;

      // Moons
      data.moons.forEach((moon, mi) => {
        const mAngle = t * moon.speed;
        const mx = Math.cos(mAngle) * moon.distance;
        const mz = Math.sin(mAngle) * moon.distance;
        const moonMeshEntry = moonMeshesRef.current.find(m => m.planetIndex === pi && m.data.name === moon.name);
        if (moonMeshEntry) {
          moonMeshEntry.mesh.position.set(mx, 0, mz);
        }
      });
    });

    // Constellation visibility
    const cGroup = sceneRef.current?.getObjectByName("constellations");
    if (cGroup) cGroup.visible = showConstellations;

    // Orbit visibility
    PLANET_DATA.forEach((_, pi) => {
      const orbitLine = sceneRef.current?.getObjectByName(`orbit_${pi}`);
      if (orbitLine) orbitLine.visible = showOrbits;
    });

    rendererRef.current?.render(sceneRef.current, cameraRef.current);
  }, [simSpeed, isPaused, showOrbits, showConstellations]);

  useEffect(() => {
    initScene();
    return () => {
      if (frameRef.current) cancelAnimationFrame(frameRef.current);
      if (rendererRef.current && mountRef.current) {
        mountRef.current.removeChild(rendererRef.current.domElement);
        rendererRef.current.dispose();
      }
    };
  }, [initScene]);

  useEffect(() => {
    if (frameRef.current) cancelAnimationFrame(frameRef.current);
    animate();
    return () => { if (frameRef.current) cancelAnimationFrame(frameRef.current); };
  }, [animate]);

  useEffect(() => {
    const handleResize = () => {
      if (!mountRef.current || !cameraRef.current || !rendererRef.current) return;
      const w = mountRef.current.clientWidth;
      const h = mountRef.current.clientHeight;
      cameraRef.current.aspect = w / h;
      cameraRef.current.updateProjectionMatrix();
      rendererRef.current.setSize(w, h);
    };
    window.addEventListener("resize", handleResize);
    return () => window.removeEventListener("resize", handleResize);
  }, []);

  const handleMouseDown = (e) => {
    mouseRef.current.isDown = true;
    mouseRef.current.lastX = e.clientX;
    mouseRef.current.lastY = e.clientY;
  };

  const handleMouseMove = (e) => {
    if (!mouseRef.current.isDown) return;
    const dx = e.clientX - mouseRef.current.lastX;
    const dy = e.clientY - mouseRef.current.lastY;
    cameraAngleRef.current.theta -= dx * 0.005;
    cameraAngleRef.current.phi = Math.max(0.15, Math.min(Math.PI - 0.15, cameraAngleRef.current.phi + dy * 0.005));
    mouseRef.current.lastX = e.clientX;
    mouseRef.current.lastY = e.clientY;
    updateCamera();
  };

  const handleMouseUp = () => { mouseRef.current.isDown = false; };

  const handleWheel = (e) => {
    cameraAngleRef.current.radius = Math.max(10, Math.min(200, cameraAngleRef.current.radius + e.deltaY * 0.05));
    updateCamera();
  };

  const handleClick = (e) => {
    if (!rendererRef.current || !cameraRef.current || !sceneRef.current) return;
    const rect = rendererRef.current.domElement.getBoundingClientRect();
    mouseVecRef.current.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouseVecRef.current.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
    raycasterRef.current.setFromCamera(mouseVecRef.current, cameraRef.current);

    const allMeshes = [];
    if (sunMeshRef.current) allMeshes.push(sunMeshRef.current);
    planetMeshesRef.current.forEach(({ group }) => {
      group.children.forEach(child => {
        if (child.isMesh) allMeshes.push(child);
      });
    });

    const hits = raycasterRef.current.intersectObjects(allMeshes, false);
    if (hits.length > 0) {
      const obj = hits[0].object;
      if (obj.userData.type === "sun") {
        setSelected({ type: "sun", data: SUN_INFO });
      } else if (obj.userData.type === "planet") {
        setSelected({ type: "planet", data: PLANET_DATA[obj.userData.index] });
      } else if (obj.userData.type === "moon") {
        const planet = PLANET_DATA[obj.userData.planetIndex];
        const moon = planet.moons[obj.userData.moonIndex];
        setSelected({ type: "moon", data: moon, parent: planet.name });
      }
    }
  };

  const handleTouchStart = (e) => {
    const t = e.touches[0];
    mouseRef.current.isDown = true;
    mouseRef.current.lastX = t.clientX;
    mouseRef.current.lastY = t.clientY;
  };
  const handleTouchMove = (e) => {
    e.preventDefault();
    const t = e.touches[0];
    handleMouseMove({ clientX: t.clientX, clientY: t.clientY });
  };
  const handleTouchEnd = () => { mouseRef.current.isDown = false; };

  const InfoField = ({ label, value }) => (
    <div style={{ marginBottom: 8 }}>
      <span style={{ color: "#8899aa", fontSize: 10, textTransform: "uppercase", letterSpacing: "1px", fontFamily: "'Orbitron', sans-serif" }}>{label}</span>
      <div style={{ color: "#e0e8f0", fontSize: 13, marginTop: 2, lineHeight: 1.5 }}>{value}</div>
    </div>
  );

  return (
    <div style={{ width: "100%", height: "100vh", position: "relative", background: "#0f171f", overflow: "hidden", fontFamily: "'Space Mono', monospace" }}>
      <div
        ref={mountRef}
        style={{ width: "100%", height: "100%", cursor: "grab" }}
        onMouseDown={handleMouseDown}
        onMouseMove={handleMouseMove}
        onMouseUp={handleMouseUp}
        onMouseLeave={handleMouseUp}
        onWheel={handleWheel}
        onClick={handleClick}
        onTouchStart={handleTouchStart}
        onTouchMove={handleTouchMove}
        onTouchEnd={handleTouchEnd}
      />

      {/* Title */}
      <div style={{ position: "absolute", top: 16, left: 16, color: "#e0e8f0", pointerEvents: "none" }}>
        <div style={{ fontSize: 20, fontWeight: 600, letterSpacing: "2px", fontFamily: "'Orbitron', sans-serif", textTransform: "uppercase", color: "#dde6ed" }}>Ray Mantra — Solar System</div>
        <div style={{ fontSize: 11, color: "#667788", marginTop: 4, letterSpacing: "0.5px" }}>Click any planet, moon, or the Sun — drag to orbit — scroll to zoom</div>
      </div>

      {/* Controls */}
      <div style={{
        position: "absolute", bottom: 16, left: 16, right: selected ? 360 : 16,
        display: "flex", alignItems: "center", gap: 12, flexWrap: "wrap",
        background: "rgba(15,23,31,0.9)", borderRadius: 10, padding: "10px 16px",
        backdropFilter: "blur(8px)", border: "1px solid rgba(221,230,237,0.08)"
      }}>
        <button onClick={() => setIsPaused(!isPaused)} style={btnStyle}>
          {isPaused ? "▶ Play" : "⏸ Pause"}
        </button>
        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
          <span style={{ color: "#667788", fontSize: 11 }}>Speed</span>
          <input type="range" min="0.1" max="5" step="0.1" value={simSpeed}
            onChange={e => setSimSpeed(parseFloat(e.target.value))}
            style={{ width: 80, accentColor: "#4a90d9" }}
          />
          <span style={{ color: "#aabbcc", fontSize: 12, minWidth: 28 }}>{simSpeed.toFixed(1)}x</span>
        </div>
        <button onClick={() => setShowOrbits(!showOrbits)} style={{ ...btnStyle, opacity: showOrbits ? 1 : 0.5 }}>
          Orbits
        </button>
        <button onClick={() => setShowLabels(!showLabels)} style={{ ...btnStyle, opacity: showLabels ? 1 : 0.5 }}>
          Labels
        </button>
        <button onClick={() => setShowConstellations(!showConstellations)} style={{ ...btnStyle, opacity: showConstellations ? 1 : 0.5 }}>
          Constellations
        </button>
        <button onClick={() => {
          cameraAngleRef.current = { theta: 0.4, phi: 1.0, radius: 80 };
          updateCamera();
        }} style={btnStyle}>
          Reset view
        </button>
      </div>

      {/* Planet quick-nav */}
      <div style={{
        position: "absolute", top: 16, right: selected ? 350 : 16,
        display: "flex", flexDirection: "column", gap: 4
      }}>
        <button onClick={() => setSelected({ type: "sun", data: SUN_INFO })}
          style={{ ...navBtnStyle, background: selected?.data?.name === "The Sun" ? "rgba(255,200,50,0.15)" : "rgba(15,23,31,0.85)" }}>
          ☀ Sun
        </button>
        {PLANET_DATA.map((p, i) => (
          <button key={p.name} onClick={() => {
            setSelected({ type: "planet", data: p });
            const angle = timeRef.current * p.speed;
            const lookX = Math.cos(angle) * p.distance;
            const lookZ = Math.sin(angle) * p.distance;
            cameraAngleRef.current.radius = p.distance + 15;
            updateCamera();
          }}
            style={{ ...navBtnStyle, background: selected?.data?.name === p.name ? "rgba(74,144,217,0.15)" : "rgba(15,23,31,0.85)" }}>
            <span style={{ display: "inline-block", width: 10, height: 10, borderRadius: "50%", background: p.color, marginRight: 6, verticalAlign: "middle" }} />
            {p.name}
          </button>
        ))}
      </div>

      {/* Info panel */}
      {selected && (
        <div style={{
          position: "absolute", top: 0, right: 0, width: 340, height: "100%",
          background: "rgba(15,23,31,0.97)", borderLeft: "1px solid rgba(221,230,237,0.1)",
          overflowY: "auto", padding: "20px", boxSizing: "border-box",
          backdropFilter: "blur(12px)"
        }}>
          <button onClick={() => setSelected(null)} style={{
            position: "absolute", top: 12, right: 12, background: "none", border: "none",
            color: "#667788", fontSize: 20, cursor: "pointer", padding: 4
          }}>✕</button>

          {selected.type === "sun" && (
            <>
              <div style={{ fontSize: 20, fontWeight: 600, color: "#ffcc33", marginBottom: 4, fontFamily: "'Orbitron', sans-serif", letterSpacing: "1px" }}>☀ {selected.data.name}</div>
              <div style={{ fontSize: 12, color: "#8899aa", marginBottom: 16 }}>{selected.data.type}</div>
              <InfoField label="Diameter" value={selected.data.diameter} />
              <InfoField label="Mass" value={selected.data.mass} />
              <InfoField label="Surface temperature" value={selected.data.surfaceTemp} />
              <InfoField label="Core temperature" value={selected.data.coreTemp} />
              <InfoField label="Age" value={selected.data.age} />
              <InfoField label="Composition" value={selected.data.composition} />
              <InfoField label="Luminosity" value={selected.data.luminosity} />
              <InfoField label="Notable features" value={selected.data.notableFeatures} />
              <div style={{ marginTop: 12, padding: "10px 12px", background: "rgba(255,200,50,0.08)", borderRadius: 8, border: "1px solid rgba(255,200,50,0.15)" }}>
                <span style={{ color: "#ffcc33", fontSize: 10, textTransform: "uppercase", fontFamily: "'Orbitron', sans-serif", letterSpacing: "1px" }}>Fun fact</span>
                <div style={{ color: "#e0e8f0", fontSize: 13, marginTop: 4, lineHeight: 1.5 }}>{selected.data.funFact}</div>
              </div>
            </>
          )}

          {selected.type === "planet" && (
            <>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 4 }}>
                <div style={{ width: 20, height: 20, borderRadius: "50%", background: selected.data.color }} />
                <div style={{ fontSize: 20, fontWeight: 600, color: "#dde6ed", fontFamily: "'Orbitron', sans-serif", letterSpacing: "1px" }}>{selected.data.name}</div>
              </div>
              <div style={{ fontSize: 12, color: "#8899aa", marginBottom: 16 }}>{selected.data.info.type}</div>
              <InfoField label="Diameter" value={selected.data.info.diameter} />
              <InfoField label="Mass" value={selected.data.info.mass} />
              <InfoField label="Surface gravity" value={selected.data.info.gravity} />
              <InfoField label="Day length" value={selected.data.info.dayLength} />
              <InfoField label="Year length" value={selected.data.info.yearLength} />
              <InfoField label="Average temperature" value={selected.data.info.avgTemp} />
              <InfoField label="Atmosphere" value={selected.data.info.atmosphere} />
              <InfoField label="Discovered by" value={selected.data.info.discoveredBy} />
              {selected.data.rings && (
                <InfoField label="Rings" value="Yes" />
              )}
              <InfoField label="Notable features" value={selected.data.info.notableFeatures} />
              <div style={{ marginTop: 12, padding: "10px 12px", background: "rgba(74,144,217,0.08)", borderRadius: 8, border: "1px solid rgba(74,144,217,0.15)" }}>
                <span style={{ color: "#4a90d9", fontSize: 10, textTransform: "uppercase", fontFamily: "'Orbitron', sans-serif", letterSpacing: "1px" }}>Fun fact</span>
                <div style={{ color: "#e0e8f0", fontSize: 13, marginTop: 4, lineHeight: 1.5 }}>{selected.data.info.funFact}</div>
              </div>

              {selected.data.moons.length > 0 && (
                <div style={{ marginTop: 16 }}>
                  <div style={{ fontSize: 11, color: "#8899aa", textTransform: "uppercase", letterSpacing: "1px", marginBottom: 8, fontFamily: "'Orbitron', sans-serif" }}>
                    Moons ({selected.data.moons.length})
                  </div>
                  {selected.data.moons.map((moon, i) => (
                    <button key={moon.name} onClick={() => setSelected({ type: "moon", data: moon, parent: selected.data.name })}
                      style={{
                        display: "flex", alignItems: "center", gap: 8, width: "100%", textAlign: "left",
                        background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.08)",
                        borderRadius: 8, padding: "8px 12px", marginBottom: 4, cursor: "pointer", color: "#c0c8d0", fontSize: 13
                      }}>
                      <span style={{ width: 8, height: 8, borderRadius: "50%", background: moon.color, flexShrink: 0 }} />
                      {moon.name}
                      <span style={{ marginLeft: "auto", color: "#556677", fontSize: 11 }}>→</span>
                    </button>
                  ))}
                </div>
              )}
            </>
          )}

          {selected.type === "moon" && (
            <>
              <button onClick={() => {
                const parent = PLANET_DATA.find(p => p.name === selected.parent);
                if (parent) setSelected({ type: "planet", data: parent });
              }} style={{ background: "none", border: "none", color: "#4a90d9", fontSize: 12, cursor: "pointer", padding: 0, marginBottom: 8 }}>
                ← Back to {selected.parent}
              </button>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 4 }}>
                <div style={{ width: 14, height: 14, borderRadius: "50%", background: selected.data.color }} />
                <div style={{ fontSize: 18, fontWeight: 600, color: "#dde6ed", fontFamily: "'Orbitron', sans-serif", letterSpacing: "1px" }}>{selected.data.name}</div>
              </div>
              <div style={{ fontSize: 12, color: "#8899aa", marginBottom: 16 }}>Moon of {selected.parent}</div>
              <InfoField label="Diameter" value={selected.data.info.diameter} />
              <InfoField label="Mass" value={selected.data.info.mass} />
              <InfoField label="Orbital period" value={selected.data.info.orbitalPeriod} />
              <InfoField label="Distance from planet" value={selected.data.info.distanceFromParent} />
              <InfoField label="Notable features" value={selected.data.info.notableFeatures} />
            </>
          )}
        </div>
      )}
    </div>
  );
}

const btnStyle = {
  background: "rgba(221,230,237,0.06)",
  border: "1px solid rgba(221,230,237,0.1)",
  color: "#dde6ed",
  padding: "6px 12px",
  borderRadius: 6,
  fontSize: 11,
  cursor: "pointer",
  whiteSpace: "nowrap",
  fontFamily: "'Orbitron', sans-serif",
  letterSpacing: "0.5px"
};

const navBtnStyle = {
  display: "flex",
  alignItems: "center",
  border: "1px solid rgba(221,230,237,0.08)",
  color: "#dde6ed",
  padding: "6px 12px",
  borderRadius: 6,
  fontSize: 11,
  cursor: "pointer",
  whiteSpace: "nowrap",
  textAlign: "left",
  minWidth: 100,
  fontFamily: "'Orbitron', sans-serif",
  letterSpacing: "0.5px"
};



ReactDOM.render(React.createElement(SolarSystem), document.getElementById('root'));
</script>
</body>
</html>
